    },
    {
      "parameters": {
        "jsCode": "const detalle = $input.first().json;\nconst factura = detalle.factura || {};\nconst causacion = detalle.causacion || {};\nconst postproceso = $node['Preparar postproceso integrado'].json || {};\n\nconst meses = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];\nconst fecha = factura.fecha_factura || new Date().toISOString().slice(0, 10);\nconst [year, month] = fecha.split('-');\nconst monthIndex = Math.max(0, Number(month || '1') - 1);\n\nfunction cleanPathPart(value, fallback) {\n  return String(value || fallback || '')\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/[<>:\"/\\\\|?*]+/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction graphPath(path) {\n  return path.split('/').map(encodeURIComponent).join('/');\n}\n\nconst rootFolder = '2. Contabilidad';\nconst receivedFolder = 'Facturas Recibidas';\nconst proveedor = cleanPathPart(factura.proveedor_nombre, 'Proveedor');\nconst numero = cleanPathPart(factura.numero_factura || factura.id, 'Factura');\nconst yearFolder = year;\nconst monthFolder = month + '.' + meses[monthIndex] + '-' + year;\nconst folderPath = [rootFolder, receivedFolder, yearFolder, monthFolder, proveedor].join('/');\nconst fileName = numero + '.pdf';\nconst oneDrivePath = folderPath + '/' + fileName;\nconst apiBaseUrl = postproceso.api_base_url || 'http://127.0.0.1:8000';\n\nreturn [{\n  json: {\n    factura_id: factura.id,\n    causacion_id: causacion.id || postproceso.causacion_id,\n    factura,\n    causacion,\n    rootFolder,\n    receivedFolder,\n    yearFolder,\n    monthFolder,\n    proveedorFolder: proveedor,\n    folderPath,\n    fileName,\n    oneDrivePath,\n    pdfDownloadUrl: apiBaseUrl + '/facturas/' + factura.id + '/pdf',\n    imapArchiveUrl: apiBaseUrl + '/correo/archivar-imap',\n    graphRootChildrenUrl: 'https://graph.microsoft.com/v1.0/me/drive/root/children',\n    graphReceivedChildrenUrl: 'https://graph.microsoft.com/v1.0/me/drive/root:/' + graphPath(rootFolder) + ':/children',\n    graphYearChildrenUrl: 'https://graph.microsoft.com/v1.0/me/drive/root:/' + graphPath([rootFolder, receivedFolder].join('/')) + ':/children',\n    graphMonthChildrenUrl: 'https://graph.microsoft.com/v1.0/me/drive/root:/' + graphPath([rootFolder, receivedFolder, yearFolder].join('/')) + ':/children',\n    graphProviderChildrenUrl: 'https://graph.microsoft.com/v1.0/me/drive/root:/' + graphPath([rootFolder, receivedFolder, yearFolder, monthFolder].join('/')) + ':/children',\n    graphUploadUrl: 'https://graph.microsoft.com/v1.0/me/drive/root:/' + graphPath(oneDrivePath) + ':/content',\n    email_subject: postproceso.email_subject || '',\n    email_from: postproceso.email_from || '',\n    email_uid: postproceso.email_uid || '',\n    email_message_id_header: postproceso.email_message_id_header || '',\n    email_source_mailbox: postproceso.email_source_mailbox || 'INBOX',\n    email_archive_mailbox: postproceso.email_archive_mailbox || 'Facturas Procesadas'\n  }\n}];"
      },
