      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of $input.all()) {\n  const binary = item.binary || {};\n\n  let zipFile = null;\n  let xmlFile = null;\n  let pdfFile = null;\n\n  for (const key of Object.keys(binary)) {\n    const file = binary[key];\n    const fileName = (file.fileName || '').toLowerCase();\n    const mimeType = (file.mimeType || '').toLowerCase();\n\n    if (fileName.endsWith('.zip') || mimeType.includes('zip')) {\n      zipFile = key;\n    }\n\n    if (fileName.endsWith('.xml') || mimeType.includes('xml')) {\n      xmlFile = key;\n    }\n\n    if (fileName.endsWith('.pdf') || mimeType.includes('pdf')) {\n      pdfFile = key;\n    }\n  }\n\n  const selectedKey = zipFile || xmlFile;\n  const tipoAdjunto = zipFile ? 'zip' : (xmlFile ? 'xml' : null);\n\n  const newBinary = { ...binary };\n\n  if (selectedKey) {\n    newBinary.factura_file = binary[selectedKey];\n  }\n\n  output.push({\n    json: {\n      subject: item.json.subject,\n      from: item.json.from,\n      date: item.json.date,\n\n      tiene_zip: !!zipFile,\n      tiene_xml: !!xmlFile,\n      tiene_pdf: !!pdfFile,\n\n      zip_binary_key: zipFile,\n      xml_binary_key: xmlFile,\n      pdf_binary_key: pdfFile,\n\n      selected_binary_key: selectedKey,\n      tipo_adjunto: tipoAdjunto,\n      nombre_adjunto: selectedKey ? binary[selectedKey].fileName : null,\n      total_adjuntos: Object.keys(binary).length,\n\n      procesable: !!selectedKey\n    },\n    binary: newBinary\n  });\n}\n\nreturn output;"
      },
