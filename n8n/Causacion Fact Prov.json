    {
      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of $input.all()) {\n  const subject = item.json.subject || '';\n  const text = item.json.text || '';\n  const html = item.json.html || '';\n  const body = text || html || '';\n\n  const subjectUpper = subject.toUpperCase();\n  const bodyUpper = body.toUpperCase();\n\n  let tipo_correo = 'FACTURA';\n\n  if (\n    bodyUpper.includes('#CAUSAR_FACTURA') ||\n    subjectUpper.includes('FACTURA REQUIERE REVISIÓN') ||\n    subjectUpper.includes('FACTURA REQUIERE REVISION')\n  ) {\n    tipo_correo = 'RESPUESTA_REVISION';\n  }\n\n  output.push({\n    json: {\n      ...item.json,\n      tipo_correo,\n      subject,\n      body_text: body\n    },\n    binary: item.binary\n  });\n}\n\nreturn output;"
      },
