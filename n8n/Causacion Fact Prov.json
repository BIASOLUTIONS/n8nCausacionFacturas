      "parameters": {
        "jsCode": "const correo = $('Clasificar correo').item.json || {};\nconst from = correo.from || '';\nconst fromText = from && from.text ? from.text : from;\nconst headers = correo.headers || {};\n\nreturn [{\n  json: {\n    factura_id: $json.factura_id,\n    causacion_id: $json.causacion_id,\n    estado: $json.estado,\n    proveedor_nit: $json.proveedor_nit,\n    proveedor_nombre: $json.proveedor_nombre,\n    numero_factura: $json.numero_factura,\n    email_subject: correo.subject || '',\n    email_from: fromText || '',\n    email_message_id_header: correo.messageId || correo.message_id || headers['message-id'] || headers.messageId || '',\n    email_uid: correo.attributes?.uid || '',\n    email_source_mailbox: 'INBOX',\n    email_archive_mailbox: 'Facturas Procesadas',\n    api_base_url: 'http://127.0.0.1:8000'\n  }\n}];"
